Checks: >
  bugprone-*
  ,clang-analyzer-*
  ,clang-diagnostic-*
  ,cppcoreguidelines-*
  ,-cppcoreguidelines-avoid-non-const-global-variables
  ,-cppcoreguidelines-pro-bounds-array-to-pointer-decay
  ,-cppcoreguidelines-pro-bounds-constant-array-index
  ,cert-dcl21-cpp
  ,cert-dcl58-cpp
  ,cert-err34-c
  ,cert-err52-cpp
  ,cert-err60-cpp
  ,cert-flp30-c
  ,cert-msc50-cpp
  ,cert-msc51-cpp
  ,cert-str34-c
  ,google-default-arguments
  ,google-explicit-constructor
  ,google-runtime-operator
  ,hicpp-*
  ,-hicpp-no-array-decay
  ,misc-*
  ,-misc-include-cleaner
  ,mpi-buffer-deref
  ,mpi-type-mismatch
  ,modernize-*
  ,-modernize-use-nodiscard
  ,-modernize-use-trailing-return-type
  ,openmp-use-default-none
  ,performance-*
  ,portability-simd-intrinsics
  ,readability-*
  ,-readability-identifier-length
  ,-*-deprecated-headers
  ,-*-magic-numbers

# Justifications for exceptions:
#
# -cppcoreguidelines-pro-bounds-array-to-pointer-decay
#   temporarily disabled (to allow for eigenSupport mappings. Need to update eigenSupport)
# -cppcoreguidelines-pro-bounds-constant-array-index
#   temporarily disabled - to be reviewed upon the inclusion of the microsoft gsl library
# -hicpp-no-array-decay
#   temporarily disabled (to allow for eigenSupport mappings. Need to update eigenSupport)
# -misc-include-cleaner
#   because there are a lot of false complaints for includes (math, Eigen, ...)
# -modernize-use-nodiscard
#   no need to follow the nodiscard suggestion
# -modernize-use-trailing-return-type
#   because this is a style change we are not ready to implement across the code base, no degradation of code quality
# -readability-identifier-length
#   because we have good use cases like K1, K2 etc. for control gains
# -*-deprecated-headers (both hicpp- and modernize-)
#   because we have to use some of the "deprecated" headers in the freestanding environment
# -*-magic-numbers (both cppcoreguidelines and readability)
#   because we often have factors (like the 2 of 2*pi) that are interpreted as a "magic number"

WarningsAsErrors: '*'
CheckOptions:
  - key: modernize-use-auto.MinTypeNameLength
    value: '5'
  - key: cppcoreguidelines-non-private-member-variables-in-classes.IgnoreClassesWithAllCapsName
    value: '1'
  - key: readability-function-size.StatementThreshold
    value: '200'
